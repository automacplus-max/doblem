# ============================================================================
# Variables de entorno — configuralas en Vercel (Project Settings > Environment
# Variables) para Production, Preview y Development. Para desarrollo local,
# copiá este archivo a .env.local y completá los valores.
# ============================================================================

# --- Supabase (base de datos real: productos, pedidos, imágenes, etc.) -----
# Se consiguen en: Supabase Dashboard > tu proyecto > Project Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Igual a VITE_SUPABASE_URL, pero sin el prefijo VITE_ (para que también la
# lean las funciones serverless del servidor, que no ven variables VITE_*).
SUPABASE_URL=

# Clave de servicio (service_role) — NUNCA la pongas con prefijo VITE_, nunca
# la expongas al navegador. Solo la usan las funciones en /api.
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin login (ver api/admin-login.js, api/admin-kv.js) -------------------
# Usuario y contraseña del panel admin. Se verifican en el servidor, nunca
# viajan al navegador.
ADMIN_USER=
ADMIN_PASSWORD=

# Secreto para firmar el token de sesión del admin. Generalo una vez con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=

# --- Stripe ------------------------------------------------------------------
# Se consiguen en: Stripe Dashboard > Developers > API keys
# Empezá siempre con las claves de TEST (sk_test_/pk_test_) hasta probar todo.
STRIPE_SECRET_KEY=

# Se genera al crear el webhook en: Stripe Dashboard > Developers > Webhooks
# (endpoint: https://tu-dominio.vercel.app/api/webhook, evento:
# checkout.session.completed)
STRIPE_WEBHOOK_SECRET=
